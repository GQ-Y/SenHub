<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.hikvision</groupId>
  <artifactId>nvr-control-service</artifactId>
  <name>Hikvision NVR Control Service</name>
  <version>1.0.0</version>
  <description>基于海康威视NVR录像机Linux端SDK开发的Java语言局域网控制服务程序</description>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.11.0</version>
        <configuration>
          <source>11</source>
          <target>11</target>
          <encoding>UTF-8</encoding>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.4.1</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>com.hikvision.nvr.Main</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <maven.compiler.source>11</maven.compiler.source>
    <jackson.version>2.15.2</jackson.version>
    <paho.version>1.2.5</paho.version>
    <maven.compiler.target>11</maven.compiler.target>
    <slf4j.version>2.0.7</slf4j.version>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <logback.version>1.4.8</logback.version>
    <jna.version>5.13.0</jna.version>
    <sqlite.version>3.42.0.0</sqlite.version>
    <yaml.version>2.14.2</yaml.version>
  </properties>
</project>
