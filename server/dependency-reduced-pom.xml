<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.digital.video.gateway</groupId>
  <artifactId>senhub-app</artifactId>
  <name>SenHub</name>
    <version>1.2.14</version>
  <description>SenHub 视频网关与安防报警服务</description>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.11.0</version>
        <configuration>
          <source>11</source>
          <target>11</target>
          <encoding>UTF-8</encoding>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.4.1</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
              </filters>
              <transformers>
                <transformer>
                  <mainClass>com.digital.video.gateway.Main</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <bcrypt.version>0.4</bcrypt.version>
    <maven.compiler.source>11</maven.compiler.source>
    <jackson.version>2.15.2</jackson.version>
    <paho.version>1.2.5</paho.version>
    <maven.compiler.target>11</maven.compiler.target>
    <spark.version>2.9.4</spark.version>
    <jwt.version>4.4.0</jwt.version>
    <slf4j.version>2.0.7</slf4j.version>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <logback.version>1.4.8</logback.version>
    <jna.version>5.13.0</jna.version>
    <sqlite.version>3.42.0.0</sqlite.version>
    <yaml.version>2.14.2</yaml.version>
  </properties>
</project>
